{
  "name": "ismail/dockyard",
  "description": "Small, Lightweight Docker container management app written in PHP.",
  "type": "project",
  "require": {
    "delight-im/auth": "^8.3",
    "jumbojett/openid-connect-php": "^1.0",
    "league/oauth2-client": "^2.9",
    "phpmailer/phpmailer": "^7.0"
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true,
    "vendor-dir": "src/vendor"
  },
  "require-dev": {
    "phpstan/phpstan": "^2.1"
  }
}
